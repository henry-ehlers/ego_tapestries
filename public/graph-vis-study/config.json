{
    "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
    "studyMetadata": {
        "title": "Graph Visualization Study",
        "version": "pilot",
        "authors": [
            "Sara Di Bartolomeo",
            "Henry Ehlers",
            "Velitchko Filipov",
            "Johann Sebastian Schicho"
        ],
        "date": "2026-02-23",
        "description": "Ego Networks Visualization Study",
        "organizations": [
            "TU Wien"
        ]
    },
    "uiConfig": {
        "contactEmail": "your@email.com",
        "helpTextPath": "graph-vis-study/assets/help.md",
        "logoPath": "revisitAssets/revisitLogoSquare.svg",
        "withProgressBar": true,
        "autoDownloadStudy": false,
        "withSidebar": true
    },
    "importedLibraries": [
        "nasa-tlx"
    ],
    "components": {
        "introduction": {
            "type": "markdown",
            "path": "graph-vis-study/assets/introduction.md",
            "response": []
        },
        "tutorial": {
            "type": "markdown",
            "path": "graph-vis-study/assets/tutorial.md",
            "response": []
        },
        "tutorial-force-directed-task1": {
            "baseComponent": "graph-vis",
            "description": "Locate the alter (i.e., non ego-node) with the largest number of neighbors.",
            "instruction": "# Task 1\nLocate the alter (i.e., non ego-node) with the largest number of neighbors.\n## How to answer\n Click on the alter to select the answer",
            "parameters": {
                "graphDataPath": "./data/star_wars_4_adapted.edges.json",
                "visualizationStyle": "force"
            }
        }
    },
    "sequence": {
        "order": "fixed",
        "components": [
            "introduction",
            "tutorial",
            "tutorial-force-directed-task1",
            "$nasa-tlx.components.nasa-tlx"
        ]
    },
    "baseComponents": {
        "graph-vis": {
            "type": "website",
            "response": [
                {
                    "id": "graphVis",
                    "prompt": "Your selected answer:",
                    "required": false,
                    "location": "belowStimulus",
                    "type": "reactive"
                }
            ],
            "path": "graph-vis-study/assets/ego_tapes/revisit.html",
            "instructionLocation": "aboveStimulus"
        }
    }
}